# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/invoiceos?schema=public"

# Auth
AUTH_SECRET="generate-a-secret-using-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Redis (for BullMQ background jobs)
REDIS_URL="redis://localhost:6379"

# GSTN / IRP — e-Invoice
IRP_CLIENT_ID=
IRP_CLIENT_SECRET=
IRP_BASE_URL=https://einv-apisandbox.nic.in

# GSP — GSTN Filing
GSP_USERNAME=
GSP_PASSWORD=
GSP_BASE_URL=

# Razorpay — Payments & Subscriptions
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_GROWTH=
RAZORPAY_PLAN_PRO=

# Storage — PDF & Assets
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION=ap-south-1

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL="InvoiceOS <invoices@yourdomain.com>"

# WhatsApp Business API
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
