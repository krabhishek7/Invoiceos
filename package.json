{
  "name": "invoiceos",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "npm run db:studio --workspace=@invoiceos/db",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace=@invoiceos/db",
    "postinstall": "npm run db:generate"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.5.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
